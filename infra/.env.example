# ============================================================
# money-contas — Environment Variables EXAMPLE
# ============================================================
# Copy this file to .env and fill in your values.
# This file IS safe to commit to version control.
# ============================================================

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=money_contas
DB_USER=money_user
DB_PASSWORD=change_me_strong_password

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=docker
JWT_SECRET=change_me_base64_encoded_secret_at_least_256bits
JWT_EXPIRATION_MS=86400000

# --- Angular / Nginx ---
FRONTEND_PORT=3000
